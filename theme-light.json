{
  "name": "QTMX Light Theme",
  "version": "1.0.0",
  "description": "Official QTMX light color theme",
  "colors": {
    "primary": "#0066FF",
    "secondary": "#00AAFF",
    "accent": "#FF0099",
    "background": "#FFFFFF",
    "surface": "#F5F5F5",
    "error": "#FF0033",
    "warning": "#FF6600",
    "success": "#00CC00",
    "info": "#0099FF"
  },
  "tokens": {
    "keyword": {
      "color": "#FF0099",
      "bold": true
    },
    "identifier": {
      "color": "#0066FF",
      "bold": false
    },
    "string": {
      "color": "#00AA00",
      "bold": false
    },
    "number": {
      "color": "#FF6600",
      "bold": false
    },
    "operator": {
      "color": "#0099FF",
      "bold": true
    },
    "comment": {
      "color": "#999999",
      "italic": true
    },
    "function": {
      "color": "#FF0099",
      "bold": true
    },
    "type": {
      "color": "#0099FF",
      "bold": true
    }
  },
  "syntax": {
    "beQ-": "#FF0099",
    "qq-": "#FF0099",
    "bbq": "#0099FF",
    "aaq": "#0099FF",
    "ingo": "#00AA00",
    "outgo": "#00AA00",
    "tcq": "#FF6600",
    "f": "#FF0099",
    "exel": "#FF0099",
    "el": "#FF0099",
    "lop": "#FF0099",
    "set": "#FF0099",
    "func": "#FF0099",
    "call": "#FF0099"
  }
}
