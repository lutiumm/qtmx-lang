{
  "name": "QTMX Dark Theme",
  "version": "1.0.0",
  "description": "Official QTMX dark color theme",
  "colors": {
    "primary": "#00FF00",
    "secondary": "#00CCFF",
    "accent": "#FF00FF",
    "background": "#0A0E27",
    "surface": "#1A1F3A",
    "error": "#FF0055",
    "warning": "#FFAA00",
    "success": "#00FF55",
    "info": "#00CCFF"
  },
  "tokens": {
    "keyword": {
      "color": "#FF00FF",
      "bold": true
    },
    "identifier": {
      "color": "#00FF00",
      "bold": false
    },
    "string": {
      "color": "#00FF55",
      "bold": false
    },
    "number": {
      "color": "#FFAA00",
      "bold": false
    },
    "operator": {
      "color": "#00CCFF",
      "bold": true
    },
    "comment": {
      "color": "#666666",
      "italic": true
    },
    "function": {
      "color": "#FF00FF",
      "bold": true
    },
    "type": {
      "color": "#00CCFF",
      "bold": true
    }
  },
  "syntax": {
    "beQ-": "#FF00FF",
    "qq-": "#FF00FF",
    "bbq": "#00CCFF",
    "aaq": "#00CCFF",
    "ingo": "#00FF55",
    "outgo": "#00FF55",
    "tcq": "#FFAA00",
    "f": "#FF00FF",
    "exel": "#FF00FF",
    "el": "#FF00FF",
    "lop": "#FF00FF",
    "set": "#FF00FF",
    "func": "#FF00FF",
    "call": "#FF00FF"
  }
}
