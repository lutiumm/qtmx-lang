{
  "editor": {
    "tabSize": 2,
    "insertSpaces": true,
    "detectIndentation": false,
    "trimAutoWhitespace": true,
    "wordWrap": "on",
    "formatOnSave": true,
    "formatOnPaste": true
  },
  "files": {
    "associations": {
      "*.qtmx-": "qtmx",
      "*.qtmx+": "qtmx",
      "*.qtmx#": "qtmx"
    }
  }
}
