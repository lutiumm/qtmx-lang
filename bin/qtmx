#!/bin/bash
# QTMX Command Line Interface v17.0.3
# Pure Language - Bootstrap Compiler (Lexer & Parser in QTMX)
# Official CLI Tool

# ===== COLOR SCHEME =====
COLOR_PRIMARY="\033[1;35m"      # Magenta - Keywords
COLOR_SECONDARY="\033[0;36m"    # Cyan - Blocks
COLOR_SUCCESS="\033[0;32m"      # Green - Success
COLOR_ERROR="\033[0;31m"        # Red - Errors
COLOR_WARNING="\033[0;33m"      # Yellow - Warnings
COLOR_INFO="\033[0;34m"         # Blue - Info
COLOR_ACCENT="\033[1;36m"       # Bright Cyan - Accents
COLOR_RESET="\033[0m"           # Reset

# ===== PATHS =====
QTMX_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
QTMX_BIN="$QTMX_ROOT/bin"
QTMX_LEXER="$QTMX_ROOT/lexer.qtmx-"
QTMX_PARSER="$QTMX_ROOT/parser.qtmx-"
QTMX_SYNTAX_SPEC="$QTMX_ROOT/SYNTAX-SPEC.md"

# ===== FUNCTIONS =====

show_header() {
  echo -e "${COLOR_PRIMARY}╔════════════════════════════════════════╗${COLOR_RESET}"
  echo -e "${COLOR_PRIMARY}║  QTMX v17.0.3                         ║${COLOR_RESET}"
  echo -e "${COLOR_PRIMARY}║  Pure Language - Bootstrap Compiler    ║${COLOR_RESET}"
  echo -e "${COLOR_PRIMARY}╚════════════════════════════════════════╝${COLOR_RESET}"
}

show_help() {
  show_header
  echo ""
  echo -e "${COLOR_INFO}Usage:${COLOR_RESET}"
  echo "  qtmx <command> [file] [options]"
  echo ""
  echo -e "${COLOR_INFO}Commands:${COLOR_RESET}"
  echo -e "  ${COLOR_SECONDARY}help${COLOR_RESET}              Show this help message"
  echo -e "  ${COLOR_SECONDARY}version${COLOR_RESET}           Show QTMX version"
  echo -e "  ${COLOR_SECONDARY}<file.qtmx->          Run QTMX file${COLOR_RESET}"
  echo -e "  ${COLOR_SECONDARY}lex <file>            Run lexer on file${COLOR_RESET}"
  echo -e "  ${COLOR_SECONDARY}parse <file>          Run parser on file${COLOR_RESET}"
  echo -e "  ${COLOR_SECONDARY}spec${COLOR_RESET}              Show language specification"
  echo -e "  ${COLOR_SECONDARY}info${COLOR_RESET}              Show QTMX information"
  echo ""
  echo -e "${COLOR_SUCCESS}Examples:${COLOR_RESET}"
  echo "  qtmx help"
  echo "  qtmx version"
  echo "  qtmx lexer.qtmx-"
  echo "  qtmx parser.qtmx-"
  echo "  qtmx lex myfile.qtmx-"
  echo "  qtmx parse myfile.qtmx-"
  echo ""
  echo -e "${COLOR_INFO}Files:${COLOR_RESET}"
  echo -e "  ${COLOR_ACCENT}Lexer${COLOR_RESET}      : $QTMX_LEXER"
  echo -e "  ${COLOR_ACCENT}Parser${COLOR_RESET}     : $QTMX_PARSER"
  echo -e "  ${COLOR_ACCENT}Specification${COLOR_RESET} : $QTMX_SYNTAX_SPEC"
  echo ""
}

show_version() {
  echo -e "${COLOR_PRIMARY}QTMX v17.0.3${COLOR_RESET}"
  echo -e "${COLOR_INFO}Edition:${COLOR_RESET} Pure (qtmx-)"
  echo -e "${COLOR_INFO}Compiler:${COLOR_RESET} Bootstrap (Lexer & Parser in QTMX)"
  echo -e "${COLOR_INFO}Language:${COLOR_RESET} QTMX"
  echo -e "${COLOR_INFO}Status:${COLOR_RESET} Development"
}

show_info() {
  show_header
  echo ""
  echo -e "${COLOR_INFO}╔══ QTMX Language Information ══╗${COLOR_RESET}"
  echo ""
  echo -e "${COLOR_SECONDARY}Components:${COLOR_RESET}"
  echo -e "  ${COLOR_PRIMARY}✓${COLOR_RESET} Lexer       (lexer.qtmx-)"
  echo -e "  ${COLOR_PRIMARY}✓${COLOR_RESET} Parser      (parser.qtmx-)"
  echo -e "  ${COLOR_WARNING}○${COLOR_RESET} Runtime     (Coming soon)"
  echo -e "  ${COLOR_WARNING}○${COLOR_RESET} Optimizer   (Coming soon)"
  echo ""
  echo -e "${COLOR_SECONDARY}Editions:${COLOR_RESET}"
  echo -e "  ${COLOR_PRIMARY}qtmx-${COLOR_RESET}  Pure Edition (Core language)"
  echo -e "  ${COLOR_WARNING}qtmx+${COLOR_RESET}  Plus Edition (With extras)"
  echo -e "  ${COLOR_WARNING}qtmx#${COLOR_RESET}  Sharp Edition (Professional)"
  echo ""
  echo -e "${COLOR_SECONDARY}Key Features:${COLOR_RESET}"
  echo -e "  • Parent-child token matching (Lexer)"
  echo -e "  • AST generation (Parser)"
  echo -e "  • Strict syntax validation"
  echo -e "  • Background processing"
  echo -e "  • PP (Preprocessing) validation"
  echo ""
  echo -e "${COLOR_SECONDARY}Keywords:${COLOR_RESET}"
  echo -e "  beQ- qq- bbq aaq ingo outgo tcq"
  echo -e "  f exel el lop set func call"
  echo ""
  echo -e "${COLOR_SECONDARY}Operators:${COLOR_RESET}"
  echo -e "  === =! < > <=> \$ // |"
  echo ""
}

show_spec() {
  if [ -f "$QTMX_SYNTAX_SPEC" ]; then
    echo -e "${COLOR_PRIMARY}QTMX Language Specification${COLOR_RESET}"
    echo ""
    head -50 "$QTMX_SYNTAX_SPEC"
    echo ""
    echo -e "${COLOR_INFO}View full specification:${COLOR_RESET}"
    echo "  less $QTMX_SYNTAX_SPEC"
  else
    echo -e "${COLOR_ERROR}Error: Specification file not found${COLOR_RESET}"
    exit 1
  fi
}

run_lexer() {
  local FILE="$1"
  
  if [ -z "$FILE" ]; then
    echo -e "${COLOR_ERROR}Error: No file specified${COLOR_RESET}"
    echo -e "${COLOR_INFO}Usage:${COLOR_RESET} qtmx lex <file.qtmx->"
    exit 1
  fi
  
  if [ ! -f "$FILE" ]; then
    echo -e "${COLOR_ERROR}Error: File not found: $FILE${COLOR_RESET}"
    exit 1
  fi
  
  echo -e "${COLOR_SUCCESS}▶ Running Lexer${COLOR_RESET}"
  echo -e "${COLOR_INFO}File:${COLOR_RESET} $FILE"
  echo -e "${COLOR_INFO}Lexer:${COLOR_RESET} $QTMX_LEXER"
  echo ""
  echo -e "${COLOR_SECONDARY}[LEXER] Tokenizing code...${COLOR_RESET}"
  echo -e "${COLOR_SECONDARY}[LEXER] Building parent-child token tree...${COLOR_RESET}"
  echo -e "${COLOR_SECONDARY}[LEXER] Running PP (Preprocessing) validation...${COLOR_RESET}"
  echo ""
  echo -e "${COLOR_SUCCESS}✓ Lexer execution ready${COLOR_RESET}"
  echo -e "${COLOR_INFO}Status:${COLOR_RESET} Pending full integration"
  echo ""
}

run_parser() {
  local FILE="$1"
  
  if [ -z "$FILE" ]; then
    echo -e "${COLOR_ERROR}Error: No file specified${COLOR_RESET}"
    echo -e "${COLOR_INFO}Usage:${COLOR_RESET} qtmx parse <file.qtmx->"
    exit 1
  fi
  
  if [ ! -f "$FILE" ]; then
    echo -e "${COLOR_ERROR}Error: File not found: $FILE${COLOR_RESET}"
    exit 1
  fi
  
  echo -e "${COLOR_SUCCESS}▶ Running Parser${COLOR_RESET}"
  echo -e "${COLOR_INFO}File:${COLOR_RESET} $FILE"
  echo -e "${COLOR_INFO}Parser:${COLOR_RESET} $QTMX_PARSER"
  echo ""
  echo -e "${COLOR_SECONDARY}[PARSER] Reading tokens...${COLOR_RESET}"
  echo -e "${COLOR_SECONDARY}[PARSER] Building Abstract Syntax Tree (AST)...${COLOR_RESET}"
  echo -e "${COLOR_SECONDARY}[PARSER] Validating AST structure...${COLOR_RESET}"
  echo ""
  echo -e "${COLOR_SUCCESS}✓ Parser execution ready${COLOR_RESET}"
  echo -e "${COLOR_INFO}Status:${COLOR_RESET} Pending full integration"
  echo ""
}

run_file() {
  local FILE="$1"
  
  if [ ! -f "$FILE" ]; then
    echo -e "${COLOR_ERROR}Error: File not found: $FILE${COLOR_RESET}"
    exit 1
  fi
  
  echo -e "${COLOR_PRIMARY}QTMX v17.0.3${COLOR_RESET}"
  echo -e "${COLOR_INFO}File:${COLOR_RESET} $FILE"
  echo ""
  echo -e "${COLOR_SECONDARY}[QTMX] Initializing...${COLOR_RESET}"
  echo -e "${COLOR_SECONDARY}[QTMX] Loading lexer.qtmx-...${COLOR_RESET}"
  echo -e "${COLOR_SECONDARY}[QTMX] Loading parser.qtmx-...${COLOR_RESET}"
  echo ""
  echo -e "${COLOR_SUCCESS}Status: Ready to execute${COLOR_RESET}"
  echo -e "${COLOR_INFO}Note:${COLOR_RESET} Full execution coming when Runtime is built in QTMX!"
  echo ""
}

# ===== MAIN HANDLER =====

COMMAND="$1"
ARGS="${@:2}"

case "$COMMAND" in
  "help" | "-h" | "--help" | "")
    show_help
    ;;
  "version" | "-v" | "--version")
    show_version
    ;;
  "info")
    show_info
    ;;
  "spec" | "specification")
    show_spec
    ;;
  "lex")
    run_lexer $ARGS
    ;;
  "parse")
    run_parser $ARGS
    ;;
  *)
    if [ -f "$COMMAND" ]; then
      run_file "$COMMAND"
    else
      echo -e "${COLOR_ERROR}✗ Unknown command: $COMMAND${COLOR_RESET}"
      echo -e "${COLOR_INFO}Type:${COLOR_RESET} qtmx help"
      exit 1
    fi
    ;;
esac
