#!/bin/bash
# QTMX Command Line Interface v2.0
# Simple wrapper that calls qtmx.qtmx-

QTMX_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
QTMX_FILE="$QTMX_ROOT/bin/qtmx.qtmx-"
COMMAND="$1"
FILE="$2"

show_help() {
  echo "QTMX v2.0.0"
  echo "Usage: qtmx <command> [file]"
  echo ""
  echo "Commands:"
  echo "  help              Show this help"
  echo "  version           Show version"
  echo "  <file.qtmx->      Run QTMX file"
  echo ""
  echo "Examples:"
  echo "  qtmx lexer.qtmx-"
  echo "  qtmx parser.qtmx-"
}

show_version() {
  echo "QTMX v2.0.0"
}

run_file() {
  if [ ! -f "$FILE" ]; then
    echo "Error: File not found: $FILE"
    exit 1
  fi
  
  echo "QTMX v2.0.0"
  echo "File: $FILE"
  echo "Status: Ready to execute"
  echo ""
  echo "Note: Full runtime execution coming when Runtime is built in QTMX!"
}

case "$COMMAND" in
  "help" | "" | "-h" | "--help")
    show_help
    ;;
  "version" | "-v" | "--version")
    show_version
    ;;
  *)
    if [ -f "$COMMAND" ]; then
      FILE="$COMMAND"
      run_file
    else
      echo "Unknown command: $COMMAND"
      echo "Type: qtmx help"
      exit 1
    fi
    ;;
esac
