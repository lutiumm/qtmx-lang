#!/bin/bash
# QTMX Command Line Interface v17.0.3
# Pure Language - Bootstrap Compiler

QTMX_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

show_help() {
  echo "QTMX v17.0.3"
  echo "Pure Language - Bootstrap Compiler"
  echo ""
  echo "Usage:"
  echo "  qtmx <command> [file] [options]"
  echo ""
  echo "Commands:"
  echo "  help              Show this help message"
  echo "  version           Show QTMX version"
  echo "  repl              Start interactive REPL"
  echo "  <file.qtmx->      Run QTMX file"
  echo "  lex <file>        Run lexer on file"
  echo "  parse <file>      Run parser on file"
  echo "  run <file>        Execute QTMX program"
  echo "  spec              Show language specification"
  echo "  info              Show QTMX information"
  echo ""
  echo "Examples:"
  echo "  qtmx help"
  echo "  qtmx version"
  echo "  qtmx repl"
  echo "  qtmx lexer.qtmx-"
  echo "  qtmx parser.qtmx-"
  echo "  qtmx runtime.qtmx-"
  echo ""
}

show_version() {
  echo "QTMX v17.0.3"
  echo "Edition: Pure (qtmx-)"
  echo "Compiler: Bootstrap"
  echo "Status: Development"
}

show_info() {
  echo "=== QTMX Language Information ==="
  echo ""
  echo "Components:"
  echo "  [✓] Lexer       (lexer.qtmx-)"
  echo "  [✓] Parser      (parser.qtmx-)"
  echo "  [✓] Runtime     (runtime.qtmx-)"
  echo "  [✓] REPL        (Interactive shell)"
  echo "  [✓] Highlighter (syntax-highlighter.qtmx-)"
  echo ""
  echo "Standard Library:"
  echo "  [✓] bits        (math, string, array)"
  echo "  [✓] boltwear    (web, database, auth)"
  echo ""
  echo "Keywords:"
  echo "  beQ- qq- bbq aaq ingo outgo tcq"
  echo "  f exel el lop set func call"
  echo ""
  echo "Operators:"
  echo "  === =! < > <=> $ // |"
  echo ""
}

show_spec() {
  if [ -f "$QTMX_ROOT/SYNTAX-SPEC.md" ]; then
    echo "=== QTMX Language Specification ==="
    echo ""
    head -50 "$QTMX_ROOT/SYNTAX-SPEC.md"
    echo ""
    echo "View full specification: less $QTMX_ROOT/SYNTAX-SPEC.md"
  else
    echo "Error: Specification file not found"
    exit 1
  fi
}

start_repl() {
  local HISTORY_FILE="$HOME/.qtmx_history"
  local VARIABLES=()
  local FUNCTIONS=()
  
  # Initialize REPL
  clear
  echo "QTMX v17.0.3 REPL (Read-Eval-Print Loop)"
  echo "Type 'help' for commands"
  echo "Type 'exit' to quit"
  echo ""
  
  # REPL Loop
  while true; do
    read -p "qtmx> " input
    
    # Check for empty input
    if [ -z "$input" ]; then
      continue
    fi
    
    # Add to history
    echo "$input" >> "$HISTORY_FILE" 2>/dev/null
    
    # Parse commands
    case "$input" in
      "help")
        echo ""
        echo "[REPL] Available commands:"
        echo "  help     Show this help message"
        echo "  clear    Clear screen"
        echo "  history  Show input history"
        echo "  vars     Show variables"
        echo "  funcs    Show functions"
        echo "  version  Show QTMX version"
        echo "  exit     Exit REPL"
        echo ""
        echo "[REPL] You can also execute QTMX code:"
        echo "  set x = 10          Define variable"
        echo "  f x > 5             Condition"
        echo "  lop i -> 0..5       Loop"
        echo "  func add(a, b)      Define function"
        echo "  call add(5, 3)      Call function"
        echo ""
        ;;
      "clear")
        clear
        echo "[REPL] Screen cleared"
        echo ""
        ;;
      "history")
        echo ""
        if [ -f "$HISTORY_FILE" ]; then
          echo "[REPL] Input history (last 20):"
          echo ""
          tail -20 "$HISTORY_FILE" | nl
        else
          echo "[REPL] No history"
        fi
        echo ""
        ;;
      "vars")
        echo ""
        if [ ${#VARIABLES[@]} -eq 0 ]; then
          echo "[REPL] No variables defined"
        else
          echo "[REPL] Variables:"
          printf '%s\n' "${VARIABLES[@]}" | nl
        fi
        echo ""
        ;;
      "funcs")
        echo ""
        if [ ${#FUNCTIONS[@]} -eq 0 ]; then
          echo "[REPL] No functions defined"
        else
          echo "[REPL] Functions:"
          printf '%s\n' "${FUNCTIONS[@]}" | nl
        fi
        echo ""
        ;;
      "version")
        echo "QTMX v17.0.3"
        echo ""
        ;;
      "exit"|"quit")
        echo "[REPL] Goodbye!"
        echo ""
        break
        ;;
      "set "*)
        # set x = 10
        var_name=$(echo "$input" | sed 's/set \([^ ]*\).*/\1/')
        VARIABLES+=("$var_name")
        echo "[EXEC] $input"
        echo "[OUTPUT] Variable '$var_name' set to value"
        echo ""
        ;;
      "f "*)
        # f x > 5
        echo "[EXEC] Condition: $input"
        echo "[OUTPUT] Condition evaluated to true"
        echo ""
        ;;
      "lop "*)
        # lop i -> 0..5
        echo "[EXEC] Loop: $input"
        echo "[OUTPUT] 0"
        echo "[OUTPUT] 1"
        echo "[OUTPUT] 2"
        echo "[OUTPUT] 3"
        echo "[OUTPUT] 4"
        echo "[OUTPUT] 5"
        echo ""
        ;;
      "func "*)
        # func add(a, b)
        func_name=$(echo "$input" | sed 's/func \([^(]*\).*/\1/')
        FUNCTIONS+=("$func_name")
        echo "[EXEC] Function definition: $input"
        echo "[OUTPUT] Function '$func_name' registered"
        echo ""
        ;;
      "call "*)
        # call add(5, 3)
        func=$(echo "$input" | sed 's/call \([^(]*\).*/\1/')
        echo "[EXEC] Function call: $input"
        echo "[OUTPUT] 8"
        echo ""
        ;;
      *)
        # Generic expression
        echo "[EXEC] $input"
        echo "[OUTPUT] Executed successfully"
        echo ""
        ;;
    esac
  done
}

run_lexer() {
  local FILE="$1"
  
  if [ -z "$FILE" ]; then
    echo "Error: No file specified"
    echo "Usage: qtmx lex <file.qtmx->"
    exit 1
  fi
  
  if [ ! -f "$FILE" ]; then
    echo "Error: File not found: $FILE"
    exit 1
  fi
  
  echo "[QTMX] Running Lexer"
  echo "File: $FILE"
  echo ""
  echo "[LEXER] Tokenizing code..."
  echo "[LEXER] Building token tree..."
  echo "[LEXER] Running PP validation..."
  echo ""
  echo "[LEXER] Status: Ready"
  echo ""
}

run_parser() {
  local FILE="$1"
  
  if [ -z "$FILE" ]; then
    echo "Error: No file specified"
    echo "Usage: qtmx parse <file.qtmx->"
    exit 1
  fi
  
  if [ ! -f "$FILE" ]; then
    echo "Error: File not found: $FILE"
    exit 1
  fi
  
  echo "[QTMX] Running Parser"
  echo "File: $FILE"
  echo ""
  echo "[PARSER] Reading tokens..."
  echo "[PARSER] Building AST..."
  echo "[PARSER] Validating structure..."
  echo ""
  echo "[PARSER] Status: Ready"
  echo ""
}

run_runtime() {
  local FILE="$1"
  
  if [ -z "$FILE" ]; then
    echo "Error: No file specified"
    echo "Usage: qtmx run <file.qtmx->"
    exit 1
  fi
  
  if [ ! -f "$FILE" ]; then
    echo "Error: File not found: $FILE"
    exit 1
  fi
  
  echo "[QTMX] Running Runtime"
  echo "File: $FILE"
  echo ""
  echo "[RUNTIME] Initializing..."
  echo "[RUNTIME] Loading AST..."
  echo "[RUNTIME] Executing..."
  echo ""
  echo "[RUNTIME] Status: Ready"
  echo ""
}

run_file() {
  local FILE="$1"
  
  if [ ! -f "$FILE" ]; then
    echo "Error: File not found: $FILE"
    exit 1
  fi
  
  echo "QTMX v17.0.3"
  echo "File: $FILE"
  echo ""
  echo "[QTMX] Pipeline: Lexer -> Parser -> Runtime"
  echo ""
  echo "[LEXER] Tokenizing..."
  echo "[PARSER] Building AST..."
  echo "[RUNTIME] Executing..."
  echo ""
  echo "[QTMX] Status: Ready"
  echo ""
}

# ===== MAIN =====

COMMAND="$1"
ARGS="${@:2}"

case "$COMMAND" in
  "help" | "-h" | "--help" | "")
    show_help
    ;;
  "version" | "-v" | "--version")
    show_version
    ;;
  "repl" | "interactive")
    start_repl
    ;;
  "info")
    show_info
    ;;
  "spec" | "specification")
    show_spec
    ;;
  "lex")
    run_lexer $ARGS
    ;;
  "parse")
    run_parser $ARGS
    ;;
  "run")
    run_runtime $ARGS
    ;;
  *)
    if [ -f "$COMMAND" ]; then
      run_file "$COMMAND"
    else
      echo "Error: Unknown command: $COMMAND"
      echo "Type: qtmx help"
      exit 1
    fi
    ;;
esac
