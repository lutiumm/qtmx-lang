#!/bin/bash
# QTMX Command Line Interface v17.0.3
# Pure Language - Bootstrap Compiler

QTMX_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

show_help() {
  echo "QTMX v17.0.3"
  echo "Pure Language - Bootstrap Compiler"
  echo ""
  echo "Usage:"
  echo "  qtmx <command> [file]"
  echo ""
  echo "Commands:"
  echo "  help              Show this help"
  echo "  version           Show version"
  echo "  <file.qtmx->      Run QTMX file"
  echo "  lex <file>        Run lexer"
  echo "  parse <file>      Run parser"
  echo "  run <file>        Run runtime"
  echo "  spec              Show specification"
  echo "  info              Show information"
  echo ""
}

show_version() {
  echo "QTMX v17.0.3"
  echo "Edition: Pure (qtmx-)"
}

show_info() {
  echo "=== QTMX Information ==="
  echo ""
  echo "[✓] Lexer       (lexer.qtmx-)"
  echo "[✓] Parser      (parser.qtmx-)"
  echo "[✓] Runtime     (runtime.qtmx-)"
  echo "[✓] Highlighter (syntax-highlighter.qtmx-)"
  echo ""
}

show_spec() {
  head -50 "$QTMX_ROOT/SYNTAX-SPEC.md"
}

run_command() {
  local CMD="$1"
  local FILE="$2"
  
  case "$CMD" in
    "lex")
      echo "[LEXER] Tokenizing: $FILE"
      ;;
    "parse")
      echo "[PARSER] Building AST: $FILE"
      ;;
    "run")
      echo "[RUNTIME] Executing: $FILE"
      ;;
    *)
      if [ -f "$CMD" ]; then
        echo "[QTMX] File: $CMD"
        echo "[QTMX] Pipeline: Lexer -> Parser -> Runtime"
      else
        echo "Error: Unknown command: $CMD"
        exit 1
      fi
      ;;
  esac
}

COMMAND="$1"
case "$COMMAND" in
  "help" | "" | "-h")
    show_help
    ;;
  "version" | "-v")
    show_version
    ;;
  "info")
    show_info
    ;;
  "spec")
    show_spec
    ;;
  *)
    run_command "$@"
    ;;
esac
