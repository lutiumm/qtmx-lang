{
  "name": "QTMX-",
  "scopeName": "source.qtmx",
  "fileTypes": ["qtmx-", "qtmx+", "qtmx#"],
  "patterns": [
    {
      "name": "comment.line.qtmx",
      "match": "//.*$"
    },
    {
      "name": "string.quoted.double.qtmx",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "keyword.control.beq.qtmx",
      "match": "\\b(beQ|beQ-)\\b"
    },
    {
      "name": "keyword.control.qq.qtmx",
      "match": "\\b(qq|qq-|qq\\+|qq#)\\b"
    },
    {
      "name": "keyword.control.block.qtmx",
      "match": "\\b(bbq|aaq)\\b"
    },
    {
      "name": "keyword.control.io.qtmx",
      "match": "\\b(ingo|outgo)\\b"
    },
    {
      "name": "keyword.control.checkpoint.qtmx",
      "match": "\\b(tcq|check)\\b"
    },
    {
      "name": "keyword.declaration.qtmx",
      "match": "\\b(module|license|endpoint|events|query|sync|emit)\\b"
    },
    {
      "name": "storage.type.qtmx",
      "match": "\\b(string|int|float|bool|array|object)\\b"
    },
    {
      "name": "constant.numeric.qtmx",
      "match": "\\b[0-9]+\\b"
    }
  ]
}
