{
  "name": "qtmx-syntax",
  "displayName": "QTMX- Syntax Highlighter",
  "version": "1.0.0",
  "publisher": "lutium",
  "engines": {
    "vscode": "^1.0.0"
  },
  "contributes": {
    "languages": [{
      "id": "qtmx",
      "aliases": ["QTMX-"],
      "extensions": [".qtmx-", ".qtmx+", ".qtmx#"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "qtmx",
      "scopeName": "source.qtmx",
      "path": "./qtmx.json"
    }],
    "themes": [{
      "label": "QTMX Dark",
      "uriFormat": "vs-dark",
      "path": "./theme-dark.json"
    }]
  }
}
